# swayidle -- idle dim / lock / DPMS and lock-before-sleep. Launched by
# river as `swayidle -w`. Timeouts are laptop-friendly and, by project
# decision, IDENTICAL on every host (laptops and desktops use the same
# power rules), so this file is not host-specific.
#
# Sequence: dim the backlight at 5 min, lock at 10 min, blank the screens
# at 15 min. Screen wakes and backlight restores on any input.
#
# Lid behaviour (turn the internal panel off, and don't suspend when an
# external monitor is attached) is handled outside swayidle -- by the
# river-lid helper and a logind drop-in installed by setup-river.

# Dim the backlight after 5 minutes; restore on resume. brightnessctl -s
# saves the current level so -r can put it back exactly.
timeout 300 'brightnessctl -s set 10%' \
	resume 'brightnessctl -r'

# Lock the screen after 10 minutes of idle. river-theme lock applies the
# current light/dark palette, then execs swaylock -f. Fall back to plain
# swaylock if the optional river-theme helper isn't installed -- the screen
# must lock either way.
timeout 600 'command -v river-theme >/dev/null 2>&1 && river-theme lock || swaylock -f'

# Turn all outputs off (DPMS) after 15 minutes; back on when input
# resumes. wlopm is the wlroots output-power tool ('*' = all outputs).
timeout 900 'wlopm --off "*"' \
	resume 'wlopm --on "*"'

# Always lock before the system sleeps, and on an explicit lock request
# (e.g. loginctl lock-session), so the screen is never left unlocked. Same
# swaylock fallback as above.
before-sleep 'command -v river-theme >/dev/null 2>&1 && river-theme lock || swaylock -f'
lock 'command -v river-theme >/dev/null 2>&1 && river-theme lock || swaylock -f'
