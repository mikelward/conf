# uwsm general environment (~/.config/uwsm/env).
#
# Used ONLY when Hyprland is launched via uwsm (opt-in — see
# config/hypr/README.md). uwsm sources this file as SHELL, so entries are
# `export KEY=VAL` and values with shell metacharacters are quoted. These
# mirror the `env = ` lines in hyprland.conf (which still apply to a plain,
# non-uwsm session) so systemd user services get the same environment.
# Hyprland-specific HYPR* variables live in env-hyprland.
export XCURSOR_SIZE=24
export QT_QPA_PLATFORM='wayland;xcb'
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export MOZ_ENABLE_WAYLAND=1
export NIXOS_OZONE_WL=1
export GTK_OVERLAY_SCROLLING=0
