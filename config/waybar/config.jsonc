// Waybar configuration
// ~/.config/waybar/config.jsonc
//
// SHARED between the Hyprland and Sway builds: modules-left lists both
// compositors' workspaces/window modules, and waybar disables the pair for
// the compositor that isn't running (a logged warning at startup, otherwise
// harmless).
//
// Left:   workspaces (Hyprland or Sway)
// Center: focused window title (Hyprland or Sway)
// Right:  three clocks (San Francisco, London, local), power profile, audio,
//         battery, tray (StatusNotifierItem), session/power menu
{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 6,

    "modules-left": ["hyprland/workspaces", "sway/workspaces"],
    "modules-center": ["hyprland/window", "sway/window"],
    "modules-right": ["clock#sf", "clock#london", "clock", "power-profiles-daemon", "pulseaudio", "network", "battery", "tray", "custom/power"],

    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{id}",
        "sort-by-number": true
    },

    "hyprland/window": {
        "max-length": 60,
        "separate-outputs": true
    },

    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": false
    },

    "sway/window": {
        "max-length": 60
    },

    // Local time (uses the system timezone).
    "clock": {
        "interval": 10,
        "format": " {:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    // London.
    "clock#london": {
        "interval": 10,
        "timezone": "Europe/London",
        "format": "LON {:%H:%M}",
        "tooltip-format": "London — {:%A %d %B, %H:%M %Z}"
    },

    // San Francisco.
    "clock#sf": {
        "interval": 10,
        "timezone": "America/Los_Angeles",
        "format": "SFO {:%H:%M}",
        "tooltip-format": "San Francisco — {:%A %d %B, %H:%M %Z}"
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " muted",
        "format-icons": {
            "headphone": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "network": {
        "format-wifi": " {signalStrength}%",
        "format-ethernet": "",
        "format-disconnected": "睊",
        "tooltip-format": "{ifname} via {gwaddr}",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo} ({power}W)"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // Session/power menu: lock, logout, suspend, reboot, shutdown via a
    // theme-aware fuzzel dmenu (see the script for the uwsm/compositor
    // logout handling).
    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh"
    }
}
