fi

test -r "$HOME"/.inputrc && export INPUTRC="$HOME"/.inputrc
test -r "$HOME"/.editrc && export EDITRC="$HOME"/.editrc

# default programs
# kitty wants EDITOR to be set even for non-interactive shells
is_runnable vi && export EDITOR=vi
