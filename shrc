# print a message describing the last error, or empty if no error
bash_last_error() {
    laststatus=$?
    case $laststatus in
    0)   ;;
    130) puts "interrupted";;
    148) ;;  # suspended
    *)   puts "status $laststatus";;
    esac
}

# print a message describing the last error, or empty if no error
sh_last_error() {
    laststatus=$?
    case $laststatus in
    0)   ;;
    *)   puts "status $laststatus";;
    esac
}
ksh_last_error() { sh_last_error "$@"; }

# print a message describing the last error, or empty if no error
zsh_last_error() {
    laststatus=$?
    case $laststatus in
    0)   ;;
    20)  ;;  # suspended (zsh < 5.0.7)
    130) puts "interrupted";;
    148) ;;  # suspended (zsh >= 5.0.7)
    *)   puts "status $laststatus";;
    esac
}

