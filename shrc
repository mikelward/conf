# stub to make vcs commands no-ops if .shrc.vcs isn't available
vcs() {
    :
}

# Load all the version control functions (git_*, hg_*, etc.).
# .shrc.vcs uses bash/zsh syntax (local, declare -a, array +=), so
# only source it under shells that actually understand it. Under
# dash/ksh/sh the stub vcs() above keeps the user's rc sourcing clean.
if test -f "$HOME/.shrc.vcs" && { is_bash || is_zsh; }; then
    . "$HOME/.shrc.vcs"
fi

fi # SHRC_LOAD_FUNCTIONS_ONLY guard (env-setup block)

switchshpool() { autoshpool switch "$1" && exit; }

# Name of the preferred session manager: "shpool" (the default when both are
# available), "tmux" (the fallback), or empty when neither is enabled/installed.
# $SESSION_BACKEND flips the preference: set it to "tmux" to prefer tmux with
# shpool as the fallback, or "shpool" (the default when unset) to prefer shpool
# with tmux as the fallback. The WANT_TMUX=0 / WANT_SHPOOL=0 opt-outs still
# disable each backend regardless of the preference.
session_backend() {
    if test "${SESSION_BACKEND:-shpool}" = tmux; then
        if test "${WANT_TMUX:-1}" != 0 && have_command tmux && have_command autotmux; then
            puts tmux
        elif test "${WANT_SHPOOL:-1}" != 0 && have_command shpool && have_command autoshpool; then
            puts shpool
        fi
    else
        if test "${WANT_SHPOOL:-1}" != 0 && have_command shpool && have_command autoshpool; then
            puts shpool
        elif test "${WANT_TMUX:-1}" != 0 && have_command tmux && have_command autotmux; then
            puts tmux
        fi
    fi
}

# Attach to (or create) this project's session using the preferred backend.
autosession() {
    case "$(session_backend)" in
        tmux)   autotmux "$@" ;;
        shpool) autoshpool "$@" ;;
    esac
}

# Switch to a session using the preferred backend. tmux switches in place
# (autotmux switch); shpool requests a switch and exits the current shell.
switchsession() {
    case "$(session_backend)" in
        tmux)   autotmux switch "$1" ;;
        shpool) switchshpool "$1" ;;
    esac
}

# Attach to a (named) session using the preferred backend.
sessionattach() {
    case "$(session_backend)" in
        tmux)   tmux attach "$@" ;;
        shpool) shpool attach "$@" ;;
    esac
}

# Detaching and making named sessions live in the scripts repo as the
# detachsession/detachtmux/detachshpool and makesession/maketmux/makeshpool
# commands (dispatchers + per-backend twins, alongside autosession and
# changesession). The ds*/ms* aliases below call those scripts.

# List sessions using the preferred backend (the vcs-aware tmuxlist /
# shpoollist helpers).
sessionlist() {
    case "$(session_backend)" in
        tmux)   tmuxlist "$@" ;;
        shpool) shpoollist "$@" ;;
    esac
}

maybe_start_session_and_exit() {
    case "$(session_backend)" in
        shpool) want_shpool && autoshpool && exit ;;
        tmux)   want_tmux   && autotmux   && exit ;;
    esac
}

