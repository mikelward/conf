# is_interactive / .shrc.local / auth blocks further down. `unalias -a`
# stays at top level (between the two guards) because bash expands
# aliases at parse time.
if test -z "${SHRC_LOAD_FUNCTIONS_ONLY:-}"; then

# Shared environment (~/.env: the canonical PATH dirs, GOPATH, ...) and
# per-host overrides (~/.env.local). Login shells already applied these
# via zshenv/profile and exported DOTENV_SOURCED, so this block is for
# shells that source shrc directly (bashrc for `ssh host cmd`, scripts
# that `. ~/.shrc`) -- same sentinel, same `set -a` form as
# zshenv/profile. Only dirs needing a glob stay as add_path calls below;
# everything unconditional lives in ~/.env.
if test -z "${DOTENV_SOURCED:-}"; then
    case $- in *a*) _dotenv_had_a=1;; *) _dotenv_had_a=0;; esac
    set -a
    for dir in "$HOME/.env" "$HOME/.env.local"; do
        test -f "$dir" && . "$dir"
    done
    test "$_dotenv_had_a" = 1 || set +a
    unset _dotenv_had_a
    export DOTENV_SOURCED=1
fi

CDPATH=".:$HOME"
GOPATH="${GOPATH:-$HOME}"
export GOPATH

# Every unconditional dir (~/scripts, ~/bin, /usr/local/bin, the SDK
# dirs, ~/.cargo/bin, ~/.local/bin, /sbin, /usr/sbin) comes from ~/.env
# above; only the globs below can't be expressed there. GOPATH defaults
# to $HOME, so $GOPATH/bin is normally already there as ~/bin; only add
# it when ~/.env.local moved GOPATH elsewhere (an unconditional `start`
# would also reorder ~/bin in front of ~/scripts).
if test "$GOPATH" != "$HOME"; then
    add_path "$GOPATH/bin" start
fi
# scripts.home, scripts.work, etc. override scripts (a glob, so it can't
# live in ~/.env; name such dirs in ~/.env.local for non-shell consumers)
for dir in "$HOME"/scripts.*; do
    add_path "$dir" start
done
for dir in /opt/*/bin; do
