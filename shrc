# Drop any inherited aliases so our function definitions below parse
# cleanly. Bash expands aliases at parse time, so e.g. a distro default
# `alias l='ls -CF'` (from /etc/bash.bashrc or the user's pre-shrc
# chain) would turn `l() { ... }` into `ls -CF() { ... }` and fail with
# a syntax error -- breaking shrc entirely. Must be at top-level (not
# inside the `if is_interactive; then` compound, and not inside the
# SHRC_LOAD_FUNCTIONS_ONLY gate below) so it executes before the rest
# of the file is parsed and alias expansion has already taken effect on
# the bodies inside. shrc is the full interactive config, so inherited
# aliases aren't meant to survive into it in the first place.
case "$shell" in
bash|zsh)
    unalias -a
    ;;
esac

# Skipped under SHRC_LOAD_FUNCTIONS_ONLY (same gate as the env-setup
# block above): every function the tests touch is defined before this
# point. Functions defined *inside* the `if is_interactive` block (zsh
# ZLE widgets, key bindings, etc.) aren't covered by tests, so it's
# fine that they don't get loaded for the test shell.
ssh_to() {
    # tell the remote host who is connecting via LC_CLIENT_HOST; set it
    # before the branch so both the rw and ssh paths carry it. The export
    # is confined to a subshell so it never leaks into the interactive
    # shell (zsh keeps a prefix assignment to a function around, unlike
    # bash). ssh only forwards env vars it's told to, so request it
    # explicitly; SendEnv is additive, so the usual LANG/LC_* forwarding
    # is left intact.
    local _client_host
    _client_host="$(short_hostname)"
    if have_command rw && test "$#" -eq 1; then
        ( export LC_CLIENT_HOST="$_client_host"; rw -r "$@" )
    else
        ( export LC_CLIENT_HOST="$_client_host"; shift_options ssh -t -oSendEnv=LC_CLIENT_HOST "$@" )
    fi
}

if test -z "${SHRC_LOAD_FUNCTIONS_ONLY:-}"; then

set_up_ssh_aliases() {
    test -f "$HOME/.ssh/config" || return 0
