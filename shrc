#!/bin/sh
#
# Configuration for bash, zsh, ksh, dash, etc.
#
# Configuration for all shells is in this one file so that it can be easily
# copied to many hosts.
#
# bashrc and zshrc should be symlinks to this file.
#
# ksh and dash should also work, but will have a simpler prompt, etc.
#
# This file can't use arrays, the (( )) form of arithmetic expansion,
# herestrings, or anything that causes a parse error in sh or dash.
# Note that the $(( )) form of arithmetic expansion appears to be OK.
#
# Mikel Ward <mikel@mikelward.com>
#

###############
# COMPATIBILITY
# Try to make all shells behave similarly while reading this file

is_zsh() {
    [ -n "${ZSH_VERSION:-}" ]
}

is_bash() {
    [ -n "${BASH_VERSION:-}" ]
}

is_dash() {
    case "$0" in */dash|dash) true;; *) false;; esac
}

is_ksh() {
    [ -n "${KSH_VERSION:-}" ]
}

is_sh() {
    case "$0" in */sh|sh) true;; *) false;; esac
}

# Failsafe for plain sh / dash: if a user (or a stray cron job) sources
# shrc under a shell that can't run the bash/zsh-heavy code below, give
# them a basic prompt and bail. The shrc functions aren't expected to
# work under dash; this is purely about not crashing on source.
# FAILSAFE=1 forces the same bail-out under bash/zsh as a cross-shell
# escape hatch when the full rc is misbehaving (e.g. autoshpool loops).
# LC_FAILSAFE=1 is accepted as an alias: openssh strips most env vars
# but most sshd configs AcceptEnv LC_*, so `LC_FAILSAFE=1 ssh host`
# lights up failsafe mode on the remote shell.
# ~/.failsafe is a persistent opt-in: `touch ~/.failsafe` to keep every
# new shell in failsafe mode without having to re-set the env var.
if is_sh || is_dash \
    || test "${FAILSAFE:-0}" = 1 \
    || test "${LC_FAILSAFE:-0}" = 1 \
    || test -e "$HOME/.failsafe"; then
    echo failsafe mode >&2
    PS1='
$(basename "$PWD")$ '
    return
fi

if is_zsh; then
    shell=zsh
elif is_bash; then
    shell=bash
elif is_ksh; then
    shell=ksh
else
    shell=sh
fi

# Re-exec into the shell named by $SHELL when it differs from the one that's
# actually running. sshd always launches the /etc/passwd login shell and
# ignores $SHELL, so the only way to switch shells without chsh is for the
# login shell to exec into $SHELL itself. Combined with ~/.env (sourced from
# .zshenv and profile before we get here), `echo 'export SHELL=/bin/bash' >>
# ~/.env` makes the next login land in bash. Doing this here -- before
# setup_shell_compat_common and all the interactive setup below -- means a zsh
# login destined for bash skips the zsh-specific setup entirely.

# want_reexec: true when we should re-exec into $SHELL. Pure policy over
# $SHELL, the running shell ($shell), and the one-shot SHELL_REEXEC_DONE
# guard, with no interactive/tty checks, so it is unit-testable. Only switches
# between shells shrc supports (bash/zsh), and only when $SHELL is a different,
# executable shell we haven't already switched into.
want_reexec() {
    test -n "${SHELL_REEXEC_DONE:-}" && return 1
    case "${SHELL:-}" in
        */bash|bash) test "$shell" = bash && return 1;;
        */zsh|zsh)   test "$shell" = zsh && return 1;;
        *) return 1;;
    esac
    command -v "$SHELL" >/dev/null 2>&1
}

# login_shell: true when this is a login shell -- the context where sshd (or a
# local login) launched the /etc/passwd shell. Used to limit the re-exec to the
# login handoff, so manually starting the other shell from an existing prompt
# (e.g. `zsh` from a bash login, where $SHELL still names bash) is left alone
# instead of being hijacked straight back into $SHELL.
login_shell() {
    if is_zsh; then
        [[ -o login ]]
    elif is_bash; then
        shopt -q login_shell
    else
        # POSIX fallback: a login shell's argv[0] is prefixed with '-'.
        case $0 in -*) return 0;; *) return 1;; esac
    fi
}

# reexec_into_shell: perform the switch if want_reexec agrees and we're an
# interactive, tty-attached *login* shell. The interactive + `test -t 0` gate
# keeps this from firing for `ssh host cmd`, scp, rsync, or cron (non-interactive
# shells that would break on any exec/output); the login_shell gate keeps it
# from hijacking a shell the user started by hand from an existing session.
# SHRC_LOAD_FUNCTIONS_ONLY (the test harness) suppresses the action while still
# defining the function. The earlier failsafe block has already returned for
# FAILSAFE/~/.failsafe, so a bad $SHELL is recoverable with `touch ~/.failsafe`.
reexec_into_shell() {
    test -n "${SHRC_LOAD_FUNCTIONS_ONLY:-}" && return
    case $- in *i*) ;; *) return;; esac
    test -t 0 || return
    login_shell || return
    want_reexec || return
    SHELL_REEXEC_DONE=1
    export SHELL_REEXEC_DONE
    exec "$SHELL" -l
}
reexec_into_shell

# Per-shell compatibility options. Defined as a function (rather than
# inline) so the test harness can replay the same setup -- especially
# `emulate sh` under zsh -- before exercising functions extracted from
# this file in isolation. Without that replay, extracted functions that
# rely on POSIX word-splitting (path, inpath, shift_options, ...) fail
# under zsh because unquoted `$PATH` doesn't split. `emulate sh` without
# -L persists to the caller's scope, so calling this function here has
# the same effect as the previous top-level case block.
setup_shell_compat_common() {
    case "$shell" in
    zsh)
        # make zsh as similar to bash as possible. Only options that affect
        # how the *rest of shrc* parses and runs belong here; the
        # interactive-only history/completion/prompt options live in
        # setup_shell_compat_interactive, which runs after the session
        # handoff so a launcher that re-execs or hands off doesn't pay for
        # setup it's about to throw away.
        emulate sh
        setopt BRACE_EXPAND
        setopt INTERACTIVE_COMMENTS
        setopt KSH_TYPESET
        # so aliases like + and - work
        unsetopt POSIX_ALIASES >/dev/null 2>&1

        # enable ksh default features
        setopt KSH_GLOB         # !(pattern) etc. like in ksh
        unsetopt BARE_GLOB_QUAL # otherwise !(pattern) breaks

        # zsh-style autoload, required for e.g. bashcompinit
        unsetopt KSH_AUTOLOAD

        # allow numeric glob (and incidentally, grouping of globs inside parens)
        unsetopt SH_GLOB
        ;;
    bash)
        # set_prompt sets PS1 to a string likely including '$', don't expand it
        shopt -u promptvars

        # enable ksh default features
        shopt -s extglob        # !(pattern) etc. like in ksh

        # enable zsh default features
        shopt -s globstar       # recursive globbing with **
        ;;
    ksh)
        alias local=typeset
        ;;
    esac
}
setup_shell_compat_common

# Interactive-only shell options, split out from setup_shell_compat_common. Called
# from the interactive block *after* the session handoff (maybe_start_session_and_exit),
# so a shell that re-execs into another shell or hands off to tmux/shpool never
# runs the zsh history/completion/prompt setopts it's about to throw away.
setup_shell_compat_interactive() {
    case "$shell" in
    zsh)
        setopt BANG_HIST
        setopt CSH_JUNKIE_HISTORY
        # so we can display jobs in the prompt
        unsetopt POSIX_JOBS >/dev/null 2>&1

        # share history between shells
        # particularly useful for zsh-autocomplete
        setopt SHARE_HISTORY
        HISTFILE=~/.zsh_history
        HISTSIZE=100000
        SAVEHIST=100000

        # make tab completion do what it says
        # e.g. in conf/config, i3s<TAB> completes to i3status/, it should
        # autocd to i3status/, not strip the slash and run i3status
        unsetopt AUTO_REMOVE_SLASH

        # set_prompt sets PS1 to a string likely including '$', don't expand it
        unsetopt PROMPT_SUBST
        ;;
    esac
}

# standardize on bash-like variables that everyone assumes are preset
: ${USERNAME:=$(id -un)}
: ${HOSTNAME:=$(hostname -f)}
: ${UID:=$(id -u)}
: ${TTY:=$(tty)}

#######
# PATH FUNCTIONS
# Functions used to modify $PATH
#
prepend_path() {
  local _dir=$1
  test -d "$_dir" || return
  delete_path "$_dir"
  if test -n "$PATH"; then
    PATH="$_dir:$PATH"
  else
    PATH="$_dir"
  fi
}

append_path() {
  local _dir=$1
  test -d "$_dir" || return
  delete_path "$_dir"
  if test -n "$PATH"; then
    PATH="$PATH:$_dir"
  else
    PATH="$_dir"
  fi
}

delete_path() {
  local _dir=$1
  PATH=$(
    _newpath=
    IFS=:
    for dir in $PATH; do
      if test "$dir" != "$_dir"; then
        _newpath=${_newpath:+$_newpath:}$dir
      fi
    done
    printf '%s' "$_newpath"
  )
}

inpath() {
  local _dir=$1
  (
    IFS=:
    for dir in $PATH; do
      if test "$dir" = "$_dir"; then
        return 0
      fi
    done
    return 1
  )
}

add_path() {
  local _dir=$1
  local _where=$2

  case "$_where" in start|end)
    delete_path "$_dir"
    case "$_where" in
    start)
      prepend_path "$_dir" || true
      ;;
    end)
      append_path "$_dir" || true
      ;;
    esac
    ;;
  *)
    if ! inpath "$_dir"; then
      append_path "$_dir" || true
    fi
    ;;
  esac
}

#################
# BASIC FUNCTIONS
# Functions that are needed elsewhere in this file.

# hook for authenticating (to ssh-agent, etc.)
a() { auth "$@"; }
auth() {
    ssh-add
}

# hook for printing which things I need to authenticate to (ssh-agent, etc.)
# Called by prompt_line; should emit a short pre-colored warning when the
# user needs to re-auth (e.g. ssh-agent has no identities) and nothing
# otherwise.
auth_info() {
    local problems=""
    is_ssh_valid || problems="$problems SSH"
    test -n "$problems" && yellow "${problems# }"
}

# ask the user whether to do something, return true if they say yes or Enter
confirm() {
    printf '%s? [Y/n] ' "$*"
    gets REPLY
    case "$REPLY" in
        [Yy]|'')
            true;;
        *)
            false
            ;;
    esac
}

connected_via_ssh() {
    test -n "${SSH_CONNECTION:-}"
}

# return true if this session is on a remote machine
connected_remotely() {
    connected_via_ssh
}

# print the connecting SSH client's hostname (best effort), or nothing and
# return non-zero if this isn't an SSH session. Tries, in order:
#   1. LC_CLIENT_HOST, smuggled through by our ssh_to (servers commonly
#      AcceptEnv LC_*, so it usually survives without server-side config)
#   2. reverse DNS of the client IP from SSH_CONNECTION
#   3. the raw client IP
ssh_client_host() {
    if test -n "${LC_CLIENT_HOST:-}"; then
        puts "$LC_CLIENT_HOST"
        return 0
    fi
    connected_via_ssh || return 1
    local _ip="${SSH_CONNECTION%% *}"
    local _name=
    if have_command getent; then
        _name="$(getent hosts "$_ip" 2>/dev/null | { gets _addr _name _rest && puts "$_name"; })"
    fi
    if test -z "$_name" && have_command dig; then
        _name="$(dig +short -x "$_ip" 2>/dev/null | { gets _name && puts "${_name%.}"; })"
    fi
    if test -n "$_name"; then
        puts "${_name%%.*}"
    else
        puts "$_ip"
    fi
}

# return true if this is inside a VCS workspace/source root
inside_project() {
    test -n "$(projectroot)"
}

# return true if this session is attached to shpool
in_shpool() {
    test -n "${SHPOOL_SESSION_NAME:-}"
}

# return true if stdin is connected to a tty. Pulled out as a helper
# so tests can stub it without rigging up a pty.
stdin_is_tty() {
    test -t 0
}

# return true if we should auto-start shpool in this session. We require the
# autoshpool helper too, not just shpool, mirroring want_tmux's autotmux gate:
# a machine that has shpool but hasn't picked up the scripts repo yet must
# fall through to the tmux path rather than erroring on a missing autoshpool
# at every shell start.
want_shpool() {
    if test "${WANT_SHPOOL:-1}" = 0; then return 1; fi
    if ! stdin_is_tty; then return 1; fi
    if in_shpool; then return 1; fi
    if inside_tmux; then return 1; fi
    if ! have_command shpool; then return 1; fi
    if ! have_command autoshpool; then return 1; fi
    connected_remotely || inside_project
}

inside_tmux() {
    test -n "${TMUX:-}"
}

# return true if we should auto-start tmux in this session. shpool is the
# default session manager; tmux is the fallback when shpool isn't installed
# or WANT_SHPOOL=0. The gating mirrors want_shpool so the two can share
# maybe_start_session_and_exit. We require the autotmux helper too, not just
# tmux: a machine that has tmux but hasn't picked up autotmux yet must fall
# through to the shpool path rather than trying to run a missing autotmux.
want_tmux() {
    if test "${WANT_TMUX:-1}" = 0; then return 1; fi
    if ! stdin_is_tty; then return 1; fi
    if inside_tmux; then return 1; fi
    if in_shpool; then return 1; fi
    if ! have_command tmux; then return 1; fi
    if ! have_command autotmux; then return 1; fi
    connected_remotely || inside_project
}

# returns whether an SSH key is loaded
is_ssh_valid() {
    ssh-add -L >/dev/null 2>&1
}

# returns whether I need to authenticate.
need_auth() {
    test -n "$(auth_info)"
}

# return true if this machine is my workstation
workstation() {
    # cache null result too.
    if test "${WORKSTATION-unset}" = "unset"; then
        WORKSTATION="$(cat "$HOME"/.workstation 2>/dev/null)"
    fi
    puts "$WORKSTATION"
}

# return true if this machine is my workstation
on_my_workstation() {
    case "$HOSTNAME" in
        "$(workstation)") true;;
        *laptop*)          false;;
        $USERNAME-*)       true;;
        *)                 false;;
    esac
}

# print a line to stdout
puts() {
    printf '%s\n' "$*"
}

# read without backslash mangling
gets() {
    read -r "$@"
}

# print an error message
error() {
    printf '%s\n' "$*" >&2
}

# return true if the argument is a shell builtin that can be invoked
is_builtin() {
    case "$(type "$1")" in *" shell builtin")
        true
        ;;
    *)
        false
        ;;
    esac
}

# return true if the argument is an alias
is_alias() {
    alias "$1" >/dev/null 2>&1
}

# return true if running the argument would run a command (and not an alias)
is_command() {
    test -x "$(command -v "$1")"
}

# return true if the argument exists as a command, bypassing aliases
have_command() {
    path "$1" >/dev/null 2>&1
}

# return true if the argument is a function
is_function() {
    case "$(type "$1" 2>/dev/null)" in *"function"*)
        true;;
    *)
        false;;
    esac
}

# return true if the argument is an alias, builtin, command, or function
is_runnable() {
    type "$1" >/dev/null 2>&1
}

# run a command as root, with shell functions available
root() {
    if is_function "$1"; then
        command root --nohome bash -c ". \"${ZDOTDIR:-$HOME}/.shrc\""'; "$@"' _ "$@"
    else
        command root --nohome "$@"
    fi
}

# return true if the shell is interactive
is_interactive() {
    case $- in *i*)
        true
        ;;
    *)
        false
        ;;
    esac
}

# log the running of a command to a file
log_history() {
    puts "$(date "+%Y%m%d %H%M%S %z") $TTY $*" >> "$HISTORY_FILE"
}

# run a command with output silenced
quiet() {
    "$@" >/dev/null 2>&1
}

# run a command, or just print what would be run if SIMULATE is true
run() {
    if ${SIMULATE:-false}; then
        puts "Would run $*"
    else
        logger -p user.info "Running $*"
        "$@"
    fi
}

# print an important message that's not quite an error
warn() {
    printf '%s\n' "$*" >&2
}

###################
# GENERAL FUNCTIONS
# Useful things that could be commands if distributing them wasn't impractical.

# print the age of a file in seconds
age() {
    local mtime="$(stat -c '%Y' "$1")"
    expr "$(date +%s)" - "$mtime"
}

# look up a hostname in DNS, output both A and AAAA records
addr() {
    dig +noall +answer +search "$1" a "$1" aaaa | get_address_records
}

ptr() {
    dig +noall +answer -x "$1" ptr | get_ptr_records
}

# read BIND-style DNS entries, print the A and AAAA records
get_address_records() {
    awk '$3 == "IN" && $4 ~ /^A/ { print $5 }'
}

# read BIND-style DNS entries, print the PTR records
get_ptr_records() {
    awk '$3 == "IN" && $4 == "PTR" { print $5 }'
}

with_address_records() {
    local hostname
    while gets hostname; do
        puts "$hostname $(join " " $(addr "$hostname"))"
    done
}

with_hostnames() {
    local ip
    while gets ip; do
        puts "$ip $(join " " $(ptr "$ip"))"
    done
}

# list this machine's IP addresses
ips() {
    ip -o a sh up primary scope global | while gets num iface afam addr rest; do
      case "$afam" in inet*)
          puts "$iface" "$addr";;
      esac
    done
}
addrs() { ips "$@"; }

# list this machine's MAC addresses
# format: <iface> <MAC addr>[\n<iface> <MAC addr>]*
macs() {
    ip -s l sh | sed -n '
/^[0-9][0-9]*:/{
s/^[0-9][0-9]*: \([^:]*\).*/\1/
h
}
/^    link\/ether/{
s/^    link\/ether \([^ ]*\).*/ \1/
H
x
s/\n//
p
}
'
}

bak() {
    local file
    for file in "$@"; do
        mv -i "$file" "${file}.bak"
    done
}

unbak() {
    local file
    for file in "$@"; do
        case "$file" in *.bak)
            test -e "$file" && mv -i "$file" "${file%.bak}"
            ;;
        *)
            test -e "${file}.bak" && mv -i "${file}.bak" "$file"
            ;;
        esac
    done
}

excd() {
    local dir
    dir="${1%.*}"
    aunpack --extract-to="$dir" "$1"
    cd "$dir"
}

# ring the terminal's bell
bell() {
    printf "\a"
}

# print the first line of input (the header) as-is, run a command
# on the rest the input (the body)
# e.g. ps | body grep ps
#
# accepts an option -<number>, makes the header <number> lines
# instead of 1
# e.g. netstat -tn | body -2 grep ':22\>'
body() {
    local lines

    lines=1
    case "$1" in -*)
        lines=${1#-}
        shift
        ;;
    esac

    while test $lines -gt 0; do
        IFS= gets header
        puts "$header"
        lines=$((lines-1))
    done
    "$@"
}

# print the path from buildroot to $PWD
builddir() {
    local buildroot=$(buildroot)
    if test "$PWD" = "$buildroot"; then
        puts "."
    else
        puts "${PWD#$(buildroot)/}"
    fi
}

# print the directory that builds are relative to
buildroot() {
    projectroot
}

# print the name of the current project
projectname() {
    basename "$(projectroot)"
}

# print the root directory of the current project
projectroot() {
    :
}

# hook to print chars like "M" = modified if there's any uncommitted changes
status_chars() {
    :
}

# cd to the real directory that the specified file is in, resolving symlinks
cdfile() {
    cd "$(realdir "$1")"
}

delline() {
    sed -i -e "${1}d" "$2"
}

# print the block device associated with the given mount point (or file)
dev() {
    df -P -k "$1" | while gets fs blocks used avail cap mount; do
        case "$mount" in /*)
            puts "$fs"
        esac
    done
}

