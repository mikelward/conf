    ms() { local b rc; b="$(session_backend)"; test -n "$TMUX$SHPOOL_SESSION_NAME$b" || return; SESSION_BACKEND="$b" makesession "$@"; rc=$?; test $rc -eq 0 && test -z "$TMUX" && test -n "$SHPOOL_SESSION_NAME" && exit; return $rc; }
