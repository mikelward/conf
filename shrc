# run a command on each line of stdin
each() {
  local _line
  while IFS=$'\n' gets _line; do
    "$@" "$_line"
  done
}

# run a command on each null-delimited parameter from stdin
each0() {
  local _arg
  while IFS= read -d '' -r _arg; do
    "$@" "$_arg"
  done
}

# see what changes a command would make to a file
# e.g. trydiff mdformat <file>
trydiff() {
    local _temp
    _temp="$2".trydiff.$$
    "$1" "$2" >"$_temp"
    diff "$2" "$_temp"
    rm "$_temp"
}

# apply the changes that trydiff would have made
# e.g. applydiff mdformat <file>
applydiff() {
    "$1" "$2" >"$2".new
    mv "$2".new "$2"
}

# print the name of a source file's corresponding test file
find_test_file() {
    local file
    local dir
    local base
    local ext
    local testfile

    file=${1##*/}
    dir=${1%$file}
    base=${file%.*}
    ext=${file#$base}

    testfile=${dir}${base}_test$ext
    [ -e "$testfile" ] && printf '%s' "$testfile"
}

# search for a file in parent directories, print the first one found
find_up() {
    (
        while true; do
            if test -f "./$1"; then
                puts "$PWD/$1"
                return 0
            fi
            if test "$PWD" = "/"; then
                return 1
            fi
            cd .. || return 1
        done
    )
}

# replace a file with a sorted version of itself
isort() {
    sort "$1" >"$1".bak
    mv "$1".bak "$1"
}

# join the arguments list by inserting a character between each element
# the first argument is the separator, the rest are the words to join
join() {
  (
    IFS=$1
    shift
    puts "$*"
  )
}

# make a directory and cd to it
mcd() {
    if test -d "$1"; then
        printf "%s already exists\n" "$1"
    else
        mkdir -p "$1" && cd "$1"
    fi
}

# make a temporary directory and cd to it
mtd() {
    cd "$(mktemp -d)"
}

# unpack a zipfile to a directory and cd to the extracted directory
ucd() {
    local _temp
    _temp="$(mktemp -p "$PWD")"
    aunpack --save-outdir="$_temp" "$1"
    local _outdir="$(cat "$_temp")"
    test -d "$_outdir" || return 1
    cd "$_outdir"
    rm "$_temp"
}

# get this machine's public IP address as seen by Google
myip() {
    dig +short o-o.myaddr.l.google.com txt @ns1.google.com | tr -d '"'
}

# print the list of nameservers
names() {
    sed -ne '/^nameserver/{s/^nameserver[[:space:]]*//;p}' /etc/resolv.conf
    nmcli dev list 2>/dev/null | sed -ne '/domain_name_servers/{s/[^ ]*: *//;p}'
    nmcli dev show 2>/dev/null | sed -ne '/^IP..DNS/{s/[^ ]*: *//;p}'
}

# list non-empty files, prefixed by timestamp in case sorting is needed
nonempty() {
    find . -size +0 "$@" -printf '%T@ %f\n'
}

# print the full path to an executable, ignoring aliases and functions
# like whence -p/type -P, but should work in all shells
path() {
    (
        IFS=:
        for d in $PATH; do
            if test -x "$d/$1"; then
                puts "$d/$1"
                return
            fi
        done
        false
    )
}

# update config files
pc() {
    for d in "$HOME/conf" "$HOME/conf".* "$HOME/scripts" "$HOME/scripts".*; do
        (
            cd "$d" || exit 0
            pull || exit 1
            if test -f ".gitmodules"; then
                git submodule init
                git submodule update
            fi
        ) || break
    done
}

# list processes in the specified process group
# pgroup <pgid> [<pgrep args>]
pgroup() {
    pgrep -g "$@"
}

# grep for a pattern in the environments of processes matching the given pattern
# pegrep <environment pattern> <process pattern>
# e.g. pegrep SSH_AUTH_SOCK xfce4
pegrep() {
    for pid in $(pgrep -f "^$2"); do
        printf '%s %s\n' "$(ps -o pid= -o args= -p "$pid")" "$(envgrep "$1" "$pid")"
    done
}
peg() { pegrep "$@"; }

# grep for a pattern in the environment of processes with the given pids
# envgrep <environment pattern> <pid>...
envgrep() {
    local pattern
    local pid
    pattern="$1"
    shift
    for pid in "$@"; do
        grep -z "$pattern" /proc/"$pid"/environ
    done
}

# ps with useful default options
psc() {
    # user,pid,ppid,pgid,start_time,pcpu,rss,comm are first, followed by any -o option
    # the user supplies, then args are last.
    ps -w -o user,pid,ppid,pgid,start_time,pcpu,rss,comm=EXE "$@" -o args=ARGS
}

# pgrep with default ps options
# psgrep [<ps options>] <pattern>
psgrep() {
    # last arg is pgrep pattern, rest are args for ps
    local ps_args
    while test $# -gt 1; do
        ps_args="$ps_args $1"
        shift
    done

    local pattern="$1"

    local pids="$(pgrep -d , -f "$pattern")"
    if test -n "$pids"; then
        psc -p "$pids" $ps_args
    else
        error "No processes matching $pattern"
        return 1
    fi
}

# print the absolute path of the directory containing the specified file
realdir() {
    dirname "$(readlink -f "$1")"
}

# show the most recently changed files
# defaults to the showing the last 10, override with -<number>
recent() {
    local lines

    lines=10
    case "$1" in -[0-9]*)
        lines=${1#-}
        shift
        ;;
    esac
    ls -t -1 "$@" | head -n "$lines"
}

# keep trying a command until it works
# (e.g. retry ping -c 1 host)
# (e.g. retry --sleep 1 ping -c 1 host)
retry() {
    local sleep=10
    if test "$1" = "--sleep"; then
        sleep=$2
        shift 2
    elif test "${1#--sleep=}" != "$1"; then
        sleep=${1#--sleep=}
        shift
    fi
    while true; do
        if "$@"; then
            bell
            break
        else
            sleep "$sleep"
        fi
    done
}

# remove the ssh known host from the specified line number
rmkey() {
    delline "$1" "$HOME/.ssh/known_hosts"
}

# run a command with the first argument moved to the end
# e.g. first_arg_last grep ~/.history <args> runs grep <args> ~/.history
first_arg_last() {
    local command
    local arg
    command=$1
    arg=$2
    shift 2
    "$command" "$@" "$arg"
}

# convert command arg1 [options] arg... to command [options] arg1 arg...
# this is useful for creating functions and aliases where you only need to
# type the second part (subcommand or object) and the command is implied,
# e.g. "somehost" runs "ssh somehost" or "commit" runs "git commit"
# (the latter is less useful, but it's the first example I could think of)
#
# e.g. alias somehost='shift_options ssh somehost' rewrites
# somehost -v hostname --fqdn =>
# ssh -v somehost hostname --fqdn
#
# requires that all options start with a hyphen/minus and not contain spaces
# options in either -fsomefile or --file=somefile format will work, but
# --file somefile will not
#
# options after -- are not shifted
# e.g. shift_options git checkout -- -b => git checkout -b
#                 => git checkout -b
shift_options() {
    local _command="$1"
    local _target="$2"
    shift 2
    local _options=
    while test -n "$1"; do
        case "$1" in
            -|--) break;;
            -*) _options="$_options $1"; shift;;
            *)  break;;
        esac
    done
    "$_command" $_options "$_target" "$@"
}

# convert a time from one timezone to another
# tz2tz <from timezone> <to timezone> <date spec>
tz2tz() {
    local from="$1"
    local to="$2"
    shift 2
    local epoch
    epoch=$(TZ="$from" date -d "$*" +%s) || return 1
    TZ="$to" date -d "@$epoch"
}

# convert from Unix timestamp in micros to a human-readable datetime string
udate() {
    local _ts=$1
    shift
    date -d @$(($_ts / 1000000)) "$@"
}

# convert from UTC to local time
utc2() {
    date -d 'TZ="UTC" '"$1"
}

# hook to run the given command under a custom ssh-agent
with_agent() {
    "$@"
}

# print the definition of the given command, alias, or function
what() {
    if is_zsh; then
        whence -f "$1"
    elif is_bash; then
        case "$(type -t "$1")" in function)
            typeset -f "$1";;
        *)
            command -v "$1";;
        esac
    else
        type "$1"
    fi
}

# run a command under set -x
setx() {
    set -x
    "$@"
    set +x
}

jc() { journalctl --no-hostname "$@"; }
sc() { systemctl "$@"; }
uc() { systemctl --user "$@"; }

# Shared body of the bash/zsh command-not-found hooks wired up below in
# the interactive section. If the missed "command" ends with a `/`, try
# to cd there (same lookup as `cd`, so CDPATH still applies); otherwise
# delegate to whichever saved system hook exists. This gives us a
# "trailing-slash autocd": typing `foo/` at the prompt changes into
# foo, while bare `foo` stays a "command not found" error.
#
# We deliberately avoid `shopt -s autocd` (bash) / `setopt AUTO_CD`
# (zsh), which auto-cd on *any* bare directory name -- far too
# aggressive and easy to trigger by accident (e.g. a typo that happens
# to name a directory). Requiring a trailing `/` makes the intent
# explicit.
# If $1 looks like a trailing-slash autocd trigger -- a single word
# ending in `/` that names an existing directory -- cd into it and
# return 0. Otherwise return 1 without side effects. Shared by the
# zsh accept-line widget and the bash DEBUG-trap hook below so that
# `foo/` reliably becomes `cd foo/` even when the shell would have
# tried (and failed) to exec the directory directly.
# Resolve $1 to an existing directory the way `cd` does, honoring
# CDPATH. Returns 0 if found, 1 otherwise. Absolute paths and paths
# starting with ./ or ../ bypass CDPATH, matching cd(1) semantics.
#
# zsh does not word-split unquoted `$CDPATH` on `:` even when IFS=: --
# splitting requires SH_WORD_SPLIT, which is off under `emulate -L
# zsh` (the _autocd_accept_line widget's mode). Use zsh's native
# `$cdpath` array form there; everything else uses POSIX IFS
# splitting.
resolve_cdpath_dir() {
    case "$1" in
    /*|./*|../*)
        test -d "$1"
        return
        ;;
    esac
    if test -d "$1"; then
        return 0
    fi
    if test -n "${ZSH_VERSION:-}"; then
        for _p in $cdpath; do
            test -z "$_p" && _p=.
            if test -d "$_p/$1"; then
                unset _p
                return 0
            fi
        done
        unset _p
        return 1
    fi
    # Walk CDPATH entries; an empty entry means `.` per POSIX.
    _oldifs="$IFS"
    IFS=:
    for _p in $CDPATH; do
        test -z "$_p" && _p=.
        if test -d "$_p/$1"; then
            IFS="$_oldifs"
            unset _oldifs _p
            return 0
        fi
    done
    IFS="$_oldifs"
    unset _oldifs _p
    return 1
}

try_autocd_trailing_slash() {
    case "$1" in
    */)
        # reject multi-word buffers like `foo/ bar`
        case "$1" in *[[:space:]]*) return 1 ;; esac
        if resolve_cdpath_dir "$1"; then
            cd -- "$1"
            return 0
        fi
        ;;
    esac
    return 1
}

maybe_autocd_trailing_slash() {
    if try_autocd_trailing_slash "$1"; then
        return 0
    fi
    if is_function system_command_not_found_handle; then
        system_command_not_found_handle "$@"
    elif is_function system_command_not_found_handler; then
        system_command_not_found_handler "$@"
    else
        printf '%s: command not found\n' "$1" >&2
        return 127
    fi
}

