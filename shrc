# TERMINAL AND PROMPT FUNCTIONS
# Functions used by the interactive shell for colors, titles, and prompt.

# detect terminal color capabilities using tput
init_colors() {
    color=false
    if is_runnable tput; then
        if quiet tput longname; then
            bold="$(tput bold)"
            underline="$(tput smul)"
            standout="$(tput smso)"
            normal="$(tput sgr0)"
            black="$(tput setaf 0)"
            red="$(tput setaf 1)"
            green="$(tput setaf 2)"
            yellow="$(tput setaf 3)"
            blue="$(tput setaf 4)"
            magenta="$(tput setaf 5)"
            cyan="$(tput setaf 6)"
            white="$(tput setaf 7)"
            color=true

            khome="$(tput khome)"
            kend="$(tput kend)"
            kdch1="$(tput kdch1)"
        fi
    fi
}

# detect terminal title escape sequences based on $TERM
init_title_sequences() {
    case "$TERM" in
    aixterm|dtterm|putty|rxvt|xterm*)
        titlestart=']0;'
        titlefinish=''
        ;;
    cygwin)
        titlestart='];'
        titlefinish=''
        ;;
    konsole)
        titlestart=']30;'
        titlefinish=''
        ;;
    screen*)
        # window title
        # screen/tmux are responsible for setting the terminal title
        titlestart='k'
        titlefinish='\'
        ;;
    *)
        if is_runnable tput; then
            if quiet tput longname; then
                titlestart="$(tput tsl)"
                titlefinish="$(tput fsl)"
            fi
        else
            titlestart=''
            titlefinish=''
        fi
        ;;
    esac
}

_color_print() {
    if $color; then
        printf '%s%s%s' "$1" "$2" "$normal"
    else
        printf '%s' "$2"
    fi
}
blue() {
    _color_print "$blue" "$*"
}
green() {
    _color_print "$green" "$*"
}
# shadows /bin/red, but I don't use it here
red() {
    _color_print "$red" "$*"
}
yellow() {
    _color_print "$yellow" "$*"
}

# prevent running "exit" if the user is still running jobs in the background
# the user is expected to close the jobs or disown them
_exit()
{
    case $- in *m*)
        # this way works in bash and zsh
        jobs | wc -l | grep -q '^ *0 *$'
        if test $? -eq 0; then
                command exit "$@"
        else
            jobs
        fi
                ;;
    *)
        command exit "$@"
        ;;
    esac
}

path_or_empty() {
    local pathname
    pathname=$(command -v "$1")
    if test -e "$pathname"; then
        puts "$pathname"
    else
        puts
    fi
}

# set a basic prompt that doesn't rely on precommand and preprompt hooks
basic_prompt() {
    PS1='$ '
    PS2='_ '
    PS3='#? '
    set_title "$(title)"
}

# commands to execute before the prompt is displayed
preprompt() {
    last_job_info
    current_command=
    SECONDS=0
    maybe_background_fetch
    # Warm the session name once so host_info and title (run in separate
    # command-substitution subshells below) reuse it instead of each
    # forking `tmux display-message`. Unset at the end so the cache is
    # scoped to this render and direct callers stay fresh.
    _session_name="$(session_name)"
    set_color 'normal'
    printf '\n'
    bar $((COLUMNS))
    printf '\r%s \n' "$(prompt_line)"
    unmerged 2>/dev/null
    job_info
    publish_jobs
    set_title "$(title)"
    set_prompt
    flash_terminal
    unset _session_name
}

# Spawn a detached background fetch via the vcs binary, which knows the
# right fetch command per VCS (git/hg/jj), the per-VCS marker file to
# mtime-gate against, and how to detach the spawned process. Called
# from preprompt; the shell only owns:
#   - PWD-change gate: most prompts don't follow a cd, so early-return.
#   - auth gate: skip when auth_info reports problems (typically no SSH
#     identity) so the prompt's {behind} indicator still nags.
maybe_background_fetch() {
    if test "$PWD" = "${_LAST_BG_FETCH_PWD:-}"; then
        return
    fi
    _LAST_BG_FETCH_PWD="$PWD"
    have_command vcs || return
    test -n "$(auth_info)" && return
    # `command` bypasses the no-op vcs() stub defined above (and any
    # shrc.vcs wrapper) so the call goes straight to the binary.
    command vcs auto-fetch >/dev/null 2>&1
}

# print the hostname and session tag for the preprompt line.
# Hostname is red on production hosts. The session tag is a green session
# name when attached to a shpool or tmux session, or a yellow warning naming
# the backend that would start when not: $SESSION_BACKEND if set, else the
# session_backend the gating would pick (shpool by default), falling back to
# shpool. The session name comes from session_name (which carries a trailing
# space for the window title); trim it for the tag.
host_info() {
    local _host="$(short_hostname)"
    if on_production_host; then
        _host="$(red "$_host")"
    fi
    local _root_info=
    if i_am_root; then
        _root_info="[$(red 'root')] "
    fi
    local _session="$(prompt_session_name)"
    _session="${_session% }"
    local _tag
    if test -n "$_session"; then
        _tag=" $(green "$_session")"
    else
        local _backend="${SESSION_BACKEND:-$(session_backend)}"
        _tag=" $(yellow "${_backend:-shpool}")"
    fi
    printf '%s%s%s' "$_root_info" "$_host" "$_tag"
}

# replace a leading $HOME in $PWD with "~"
tilde_pwd() {
    case "$PWD" in
        "$HOME")    puts "~" ;;
        "$HOME"/*)  puts "~${PWD#"$HOME"}" ;;
        *)          puts "$PWD" ;;
    esac
}

# print the directory info for the preprompt line. Inside a project we call
# `vcs prompt-info` (one fork); outside, we fall back to a tilde-expanded
# $PWD. The whole thing is wrapped in blue.
dir_info() {
    local _info=
    if inside_project && is_function prompt_info; then
        local _color_flag=--color=never
        if $color; then
            _color_flag=--color=always
        fi
        _info="$(prompt_info "$_color_flag")"
    fi
    if test -z "$_info"; then
        _info="$(tilde_pwd)"
    fi
    blue "$_info"
}

# print the first line of the preprompt: host + dir + auth.
# Composed in-shell from host_info, dir_info, and auth_info. The VCS part
# is delegated to `vcs prompt-info`; the rest is pure shell. auth_info is
# captured once so ssh-add -L (via is_ssh_valid) only runs one time per
# prompt — calling need_auth and auth_info separately would double that.
prompt_line() {
    local _auth="$(auth_info)"
    local _out="$(host_info) $(dir_info)"
    if test -n "$_auth"; then
        _out="$_out $_auth"
    fi
    puts "$_out"
}

maybe_space() {
    test -n "$*" && printf ' %s' "$*"
}

bar() {
    local _i=0
    while test $_i -lt $1; do
        printf '―'
        _i=$((_i+1))
    done
}

last_job_info() {
    # Must be the very first thing.
    local last_error="$(${shell}_last_error)"

    test -z "$current_command" && return

    set_color 'normal'
    local printed=false
    if test -n "$last_error"; then
        red "$last_error"
        printed=true
    fi
    local duration=
    if test "$SECONDS" -gt 0; then
        local hours minutes seconds
        seconds="$SECONDS"
        hours=$(($seconds/3600))
        seconds=$(($seconds-$hours*3600))
        minutes=$(($seconds/60))
        seconds=$(($seconds-$minutes*60))
        if test "$hours" -gt 0; then
            duration="$hours hours $minutes minutes $seconds seconds"
        elif test "$minutes" -gt 0; then
            duration="$minutes minutes $seconds seconds"
        elif test "$seconds" -gt 1; then
            duration="$seconds seconds"
        fi
    fi
    if test -n "$duration"; then
        if $printed; then
            printf ' '
        fi
        yellow "took $duration"
        printed=true
    fi
    if $printed; then
        printf '\n'
    fi
}

# get the user's attention
flash_terminal() {
    case $TERM in xterm|xterm-*)
        bell
        ;;
    esac
}

# return true if the current user is root
i_am_root() {
    test $UID -eq 0
}

# return true if this machine is my laptop
_on_my_laptop() {
    if test -f "$HOME"/.laptop; then
        true
    else
        case "$HOSTNAME" in
        *laptop*) true;;
        *)        false;;
        esac
    fi
}

# return true if this machine is my laptop
on_my_laptop() {
    if test -z "${LAPTOP:-}"; then
        if _on_my_laptop; then
            LAPTOP=true
        else
            LAPTOP=false
        fi
    fi
    "$LAPTOP"
}

# return true if this is a non-production machine I use to get work done
on_my_machine() {
    on_my_workstation || on_my_laptop
}

# return true if it's already obvious which host I'm on
show_hostname_in_title() {
    ! inside_tmux
}

# return true if this machine is a production machine
on_production_host() {
    ! on_my_machine && ! on_test_host && ! on_dev_host
}

# return true if this machine is a test (i.e. non production) machine
on_test_host() {
    case "$HOSTNAME" in
        *test*) true;;
        *)      false;;
    esac
}

on_dev_host() {
    case "$HOSTNAME" in
        *dev*) true;;
        *)     false;;
    esac
}

# print information about all shell jobs on a single line.
# intended to be used in the preprompt
job_info() {
        local _out
        _out="$(jobs |
            sed -e 's/^\[\([0-9][0-9]*\)\][-+ ]*[^ ]* */%\1 /' |
            grep -v '(pwd now:' |
            tr '\n' ' ')"
        _out="${_out% }"
        test -n "$_out" && printf '%s\n' "$_out"
}

# Resolve the per-shell file publish_jobs writes a short summary of
# the current shell's job table to, so a status-bar consumer (tmux,
# screen, ...) can display it without having to query a foreign
# shell's job table. Keyed by $TTY (the pty path) rather than the
# multiplexer's pane id so the same scheme works in any multiplexer,
# and outside of one. Empty (and publishing is silently disabled)
# when $TTY isn't a /dev/... path (e.g. under the test harness) or
# when $XDG_RUNTIME_DIR isn't set -- we deliberately avoid a /tmp
# fallback because a predictable per-uid path under /tmp lets a local
# user pre-create the leaf as a symlink and have the victim's shell
# truncate the symlink target on every prompt. $XDG_RUNTIME_DIR is
# per-user mode 0700 on modern Linux, so it sidesteps that. Computed
# once and cached in _JOB_PUBLISH_FILE.
publish_jobs_file() {
    if test -z "${_JOB_PUBLISH_FILE_INIT:-}"; then
        _JOB_PUBLISH_FILE_INIT=1
        _JOB_PUBLISH_FILE=
        case "${TTY:-}" in /dev/?*)
            if test -n "${XDG_RUNTIME_DIR:-}"; then
                _JOB_PUBLISH_FILE="$XDG_RUNTIME_DIR/shell-jobs$TTY"
            fi
            ;;
        esac
    fi
    puts "$_JOB_PUBLISH_FILE"
}

# Write a single-line "%N command %M command ..." summary of the
# current shell's job table to publish_jobs_file (e.g. "%1 vi %2
# tail"). Called from preprompt so the value refreshes on every
# prompt redraw. job_info emits "%N command args & %M command args &"
# (one line, all jobs joined); we walk the fields, grab the word
# after each "%N" token, and drop the trailing args. An empty file
# means "no jobs", so the consumer can just `cat` the file without
# further parsing. No-op when the publish file can't be resolved (no
# tty).
publish_jobs() {
    local _file
    _file=$(publish_jobs_file)
    test -n "$_file" || return
    local _dir=${_file%/*}
    mkdir -p "$_dir" 2>/dev/null || return
    # The `jobs` builtin's view of the job table is cleared in a
    # pipeline left-side subshell, so `job_info | awk` would silently
    # see zero jobs even when there are some. Command substitution
    # preserves the table, so capture first and pipe the text.
    local _info
    _info=$(job_info)
    printf '%s\n' "$_info" | awk '
        { for (i = 1; i <= NF; i++)
            if ($i ~ /^%[0-9]+$/ && (i+1) <= NF)
                printf "%s %s ", $i, $(i+1) }
    ' > "$_file"
}

# Remove this shell's publish file. Installed as the EXIT trap in the
# interactive block below so the file doesn't linger after the shell
# exits and confuse the next shell on the same pty.
unpublish_jobs() {
    local _file
    _file=$(publish_jobs_file)
    test -n "$_file" || return
    rm -f "$_file"
}

short_pwd() {
    local projectname="$(projectname)"
    if test -n "$projectname"; then
        printf '%s' "$projectname"
