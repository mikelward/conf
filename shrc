# print a message describing the last error, or empty if no error
bash_last_error() {
    laststatus=$?
    case $laststatus in
    0)   ;;
    130) puts "interrupted";;
    148) ;;  # suspended
    *)   puts "status $laststatus";;
    esac
}

# print a message describing the last error, or empty if no error
sh_last_error() {
