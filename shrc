# print a message describing the last error, or empty if no error
zsh_last_error() {
    laststatus=$?
    case $laststatus in
    0)   ;;
    20)  ;;  # suspended (zsh < 5.0.7)
    130) puts "interrupted";;
    148) ;;  # suspended (zsh >= 5.0.7)
