# Resolve the session name for the current prompt. preprompt warms
# _session_name once per render so prompt_line/host_info and set_title/title
# share a single `tmux display-message` fork instead of forking twice. The
# variable being set (even to an empty value) means warmed; preprompt unsets
# it after the render, so direct callers (e.g. basic_prompt, tests) fall back
# to session_name.
prompt_session_name() {
    if test -n "${_session_name+set}"; then
        printf '%s' "$_session_name"
    else
        session_name
    fi
}

trim_prefix() {
