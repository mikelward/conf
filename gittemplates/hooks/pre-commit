#!/bin/bash

root=$(git rev-parse --show-toplevel)
cd "$root" || exit 1

# Prefer the personal .Makefile generated by `makemakefile` if present
# (lets it wrap whatever build system the project uses without
# clobbering the project's real Makefile). Fall back to the project's
# own Makefile in environments where .Makefile hasn't been generated
# (fresh clones, CI, sandboxes).
if test -f .Makefile; then
    exec make -f .Makefile test
else
    exec make test
fi
