#!/bin/sh
# In conf, pull the ./vcs clone to its remote HEAD after a pull/merge.
# Test for vcs/.git rather than `git -C vcs rev-parse --git-dir`: the
# latter walks up and finds the parent conf repo when vcs/ exists as a
# plain directory, which would silently `pull` from conf.
if test -e vcs/.git; then
    git -C vcs pull
fi
